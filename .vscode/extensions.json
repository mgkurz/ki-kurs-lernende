{
  // Empfohlene Erweiterungen für dieses Projekt (HTML5 / CSS3 / Vanilla JS, OER).
  // VS Code schlägt sie beim Öffnen des Repos zur Installation vor.
  // Bewusst NICHT empfohlen: Color-Themes (Geschmack) und Python (nicht im Stack).
  "recommendations": [
    // Claude Code: KI-Assistenz direkt im Editor
    "anthropic.claude-code",

    // Live-Vorschau der HTML-Artefakte im lokalen Server
    "ms-vscode.live-server",

    // Automatische, konsistente Formatierung von HTML/CSS/JS/MD
    "esbenp.prettier-vscode",

    // Barrierefreiheit: prüft alt-Texte, Kontraste, Heading-Hierarchie (Projektanforderung)
    "deque-systems.vscode-axe-linter",

    // Saubere Markdown-Struktur (Übergaben, Recherche, docs/)
    "davidanson.vscode-markdownlint",

    // Einheitliche Einrückung/Zeilenenden gemäß .editorconfig
    "editorconfig.editorconfig",

    // Rechtschreibprüfung für die textlastigen deutschen Lernmaterialien
    "streetsidesoftware.code-spell-checker",
    "streetsidesoftware.code-spell-checker-german"
  ],

  // Erweiterungen, von denen VS Code in diesem Repo abrät (optional, hier leer gelassen)
  "unwantedRecommendations": []
}
